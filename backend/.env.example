PORT=3000
MONGODB_URI=mongodb://localhost:27017/wifi_marketing

# Cloudinary (Image Processing)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Cloudflare R2 (Storage & Edge Caching)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-public-edge-url.com

# Google Drive (If using API keys for direct downloads)
# GOOGLE_DRIVE_API_KEY=your_key
