# MikroTik WiFi Marketing SPA - Environment Setup
# ----------------------------------------------
# 1. Copy this file to .env (cp .env.example .env)
# 2. VITE_BRAND should match the brandId in CMS Database

# The main brand identifier for local development
VITE_BRAND=lalot

# Use local CMS if running locally, otherwise your production domain
VITE_API_URL=http://localhost:3000
